<Window x:Class="ProjectOOP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CryptoTracker" Height="700" Width="1000"
        Background="#0D0F14"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="BgCard"      Color="#1A1E2A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8EAF0"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#6B7280"/>
        <SolidColorBrush x:Key="AccentGold"  Color="#F0B429"/>
        <SolidColorBrush x:Key="Green"       Color="#10B981"/>
        <SolidColorBrush x:Key="Red"         Color="#EF4444"/>

        <!-- Single reusable button style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1A1E2A"/>
            <Setter Property="Foreground" Value="#E8EAF0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <!-- ListBox item -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222636"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E2433"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Border Grid.Row="0" Background="#13161E"
                MouseLeftButtonDown="TitleBar_MouseDown">
            <DockPanel Margin="16,0">
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="₿ CRYPTO" FontSize="14" FontWeight="Bold"
                               Foreground="#F0B429" VerticalAlignment="Center"/>
                    <TextBlock Text="TRACKER" FontSize="14"
                               Foreground="#E8EAF0" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Window controls -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="⟳" Click="RefreshBtn_Click" ToolTip="Vernieuwen" Margin="2,0"/>
                    <Button Content="─" Click="MinimizeBtn_Click" Margin="2,0"/>
                    <Button Content="✕" Click="CloseBtn_Click"    Margin="2,0"/>
                </StackPanel>

                <!-- Status -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="7" Height="7"
                             Fill="#10B981" Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText"    Text="Live"  FontSize="11" Foreground="#6B7280"/>
                    <TextBlock x:Name="LastUpdatedText" Text=""    FontSize="11" Foreground="#4B5563" Margin="8,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0" Background="#13161E"
                    BorderBrush="#2A2F3D" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Tabs + search at top -->
                    <StackPanel DockPanel.Dock="Top" Margin="10,10,10,6">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="TabAll" Content="Alle"
                                    Click="TabAll_Click" Margin="0,0,4,0"/>
                            <Button x:Name="TabFav" Content="★ Favorieten"
                                    Click="TabFav_Click"/>
                        </StackPanel>
                        <TextBox x:Name="SearchBox"
                                 Background="#1A1E2A" Foreground="#E8EAF0"
                                 BorderBrush="#2A2F3D" CaretBrush="#F0B429"
                                 Padding="8,6" FontSize="13"
                                 TextChanged="SearchBox_TextChanged"/>
                    </StackPanel>

                    <!-- List -->
                    <ListBox x:Name="CryptoListBox"
                             Background="Transparent" BorderThickness="0"
                             Margin="6,0,6,6"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="CryptoListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding Rank}"
                                               FontSize="11" Foreground="#4B5563"
                                               VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#E8EAF0"/>
                                        <TextBlock Text="{Binding Symbol}"
                                                   FontSize="11" Foreground="#6B7280"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding PriceFormatted}"
                                                   FontSize="13" Foreground="#E8EAF0"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding ChangeFormatted}"
                                                   FontSize="11" Foreground="{Binding ChangeColor}"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- RIGHT PANEL -->
            <Grid Grid.Column="1">
                <!-- Empty state -->
                <StackPanel x:Name="EmptyState"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="₿" FontSize="48" Foreground="#2A2F3D"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Selecteer een coin" FontSize="16"
                               Foreground="#4B5563" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Detail view -->
                <Grid x:Name="DetailView" Visibility="Collapsed" Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right" x:Name="FavBtn"
                                Click="FavBtn_Click" VerticalAlignment="Top"
                                Background="Transparent">
                            <TextBlock x:Name="FavBtnText" Text="☆"
                                       FontSize="22" Foreground="#6B7280"/>
                        </Button>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock x:Name="DetailName"
                                           FontSize="26" FontWeight="Bold" Foreground="#E8EAF0"/>
                                <TextBlock x:Name="DetailSymbol"
                                           FontSize="12" Foreground="#6B7280"
                                           VerticalAlignment="Bottom" Margin="8,0,0,4"/>
                                <TextBlock x:Name="DetailRank"
                                           FontSize="12" Foreground="#F0B429"
                                           VerticalAlignment="Bottom" Margin="6,0,0,4"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="DetailPrice"
                                           FontSize="32" FontWeight="Bold" Foreground="#E8EAF0"/>
                                <Border x:Name="ChangeBadge" CornerRadius="4"
                                        Margin="10,6,0,0" Padding="8,3" VerticalAlignment="Center">
                                    <TextBlock x:Name="DetailChange"
                                               FontSize="13" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>

                    <!-- Stats row -->
                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
                        <Border Background="#1A1E2A" CornerRadius="8" Padding="14,10" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="MARKTKAPITALISATIE" FontSize="10" Foreground="#6B7280"/>
                                <TextBlock x:Name="StatMarketCap" FontSize="15" FontWeight="SemiBold"
                                           Foreground="#E8EAF0" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A1E2A" CornerRadius="8" Padding="14,10" Margin="3,0">
                            <StackPanel>
                                <TextBlock Text="24U VOLUME" FontSize="10" Foreground="#6B7280"/>
                                <TextBlock x:Name="StatVolume" FontSize="15" FontWeight="SemiBold"
                                           Foreground="#E8EAF0" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#1A1E2A" CornerRadius="8" Padding="14,10" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="CIRCULEREND AANBOD" FontSize="10" Foreground="#6B7280"/>
                                <TextBlock x:Name="StatSupply" FontSize="15" FontWeight="SemiBold"
                                           Foreground="#E8EAF0" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Chart -->
                    <Border Grid.Row="2" Background="#1A1E2A" CornerRadius="10" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Prijsverloop (7 dagen)"
                                       FontSize="12" Foreground="#9CA3AF" Margin="0,0,0,10"/>
                            <Canvas Grid.Row="1" x:Name="ChartCanvas" ClipToBounds="True"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
